# =============================================================================
# Quench .env — provider keys, model chains, and runtime settings.
# Safe to copy: cp .env.example .env, then fill in keys you have.
# =============================================================================


# -----------------------------------------------------------------------------
# Model chains (the headline feature)
# -----------------------------------------------------------------------------
# Each MODEL_* slot maps a Claude model class to one or more upstream models.
# Format:    provider_id/model_path[|provider_id/model_path|...]
# Providers: nvidia_nim | open_router | deepseek | lmstudio | llamacpp | ollama
#
# Pipe-separated chains: walked left to right. On 401 (auth/quota),
# 429 (rate limit), or 5xx/529 (overloaded), the active entry is quenched
# for a TTL (1h auth, 60s rate-limit, 30s overloaded) and the next entry
# transparently takes over. Single values still work unchanged.
#
# Example chain:
#   MODEL_SONNET="nvidia_nim/qwen/qwen3-coder-480b-a35b-instruct|nvidia_nim/openai/gpt-oss-120b|open_router/google/gemma-4-31b-it:free"
#
# Empty MODEL_OPUS / MODEL_SONNET / MODEL_HAIKU inherit MODEL.

MODEL_OPUS=
MODEL_SONNET=
MODEL_HAIKU=
MODEL="nvidia_nim/z-ai/glm4.7"

# Per-Claude-model thinking switches. Empty inherits ENABLE_MODEL_THINKING.
ENABLE_OPUS_THINKING=
ENABLE_SONNET_THINKING=
ENABLE_HAIKU_THINKING=
ENABLE_MODEL_THINKING=true


# -----------------------------------------------------------------------------
# Provider credentials
# -----------------------------------------------------------------------------
# Free tier:
NVIDIA_NIM_API_KEY=""             # https://build.nvidia.com/settings/api-keys (40 req/min)
OPENROUTER_API_KEY=""             # https://openrouter.ai/keys (free models on `:free` suffix)

# Paid:
DEEPSEEK_API_KEY=""               # https://platform.deepseek.com/api_keys (~$0.14 / M tokens)

# Local (no key required):
OLLAMA_BASE_URL="http://localhost:11434"
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
LLAMACPP_BASE_URL="http://localhost:8080/v1"


# -----------------------------------------------------------------------------
# Provider transport (optional)
# -----------------------------------------------------------------------------
# Per-provider HTTP/SOCKS5 proxy: "http://user:pass@host:port" or "socks5://..."
NVIDIA_NIM_PROXY=""
OPENROUTER_PROXY=""
LMSTUDIO_PROXY=""
LLAMACPP_PROXY=""

# Provider-side throttling (in-process, before upstream call).
PROVIDER_RATE_LIMIT=1
PROVIDER_RATE_WINDOW=3
PROVIDER_MAX_CONCURRENCY=5

# HTTP client timeouts (seconds).
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=10


# -----------------------------------------------------------------------------
# Quench server auth and binding
# -----------------------------------------------------------------------------
# Optional bearer token clients must send. **Set this whenever the proxy is
# reachable from anything other than 127.0.0.1.**
ANTHROPIC_AUTH_TOKEN=

# Bind / port / log file are managed by the `./quench` CLI via env vars
# (QUENCH_HOST, QUENCH_PORT, QUENCH_LOG, QUENCH_START_TIMEOUT).


# -----------------------------------------------------------------------------
# Discord / Telegram bot (optional)
# -----------------------------------------------------------------------------
MESSAGING_PLATFORM="discord"      # "telegram" | "discord" | "none"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1

TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""

DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""


# -----------------------------------------------------------------------------
# Voice note transcription (optional)
# -----------------------------------------------------------------------------
VOICE_NOTE_ENABLED=false

# WHISPER_DEVICE:
#   "cpu"/"cuda"  Hugging Face transformers Whisper, offline + free.
#                 Install: uv sync --extra voice_local
#   "nvidia_nim"  NVIDIA NIM Whisper via Riva gRPC (needs NVIDIA_NIM_API_KEY).
#                 Install: uv sync --extra voice
# Independent of the chat MODEL=nvidia_nim/... setting.
WHISPER_DEVICE="nvidia_nim"

# WHISPER_MODEL:
#   cpu/cuda    Hugging Face ID or short name (tiny/base/small/medium/large-v2/large-v3/large-v3-turbo)
#   nvidia_nim  e.g. "nvidia/parakeet-ctc-1.1b-asr", "openai/whisper-large-v3" (recommended)
WHISPER_MODEL="openai/whisper-large-v3"

HF_TOKEN=""


# -----------------------------------------------------------------------------
# Bot Claude CLI integration (optional)
# -----------------------------------------------------------------------------
CLAUDE_WORKSPACE="./agent_workspace"
ALLOWED_DIR=""
CLAUDE_CLI_BIN="claude"
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true


# -----------------------------------------------------------------------------
# Web tools (Anthropic web_search / web_fetch handled locally; outbound HTTP)
# -----------------------------------------------------------------------------
ENABLE_WEB_SERVER_TOOLS=true
WEB_FETCH_ALLOWED_SCHEMES=http,https
# OFF by default. Setting true lets local web tools reach RFC1918 ranges
# (LAN, private IPs). Only enable on a trusted network.
WEB_FETCH_ALLOW_PRIVATE_NETWORKS=false


# -----------------------------------------------------------------------------
# Logging (off by default to avoid leaking request content)
# -----------------------------------------------------------------------------
DEBUG_PLATFORM_EDITS=false
DEBUG_SUBAGENT_STACK=false

# Logs raw API request/response payloads. Useful for debugging, dangerous in production.
LOG_RAW_API_PAYLOADS=false

# Logs raw SSE event bodies. May include user prompts and model output.
LOG_RAW_SSE_EVENTS=false

# Logs full exception text and tracebacks. May leak request-derived data
# (Pydantic validation errors can echo API keys).
LOG_API_ERROR_TRACEBACKS=false

# Logs message/transcription previews in messaging adapters. May leak user content.
LOG_RAW_MESSAGING_CONTENT=false

# Logs full Claude CLI stderr and parser error text.
LOG_RAW_CLI_DIAGNOSTICS=false

# Logs full exception strings in messaging error paths. May leak user content.
LOG_MESSAGING_ERROR_DETAILS=false
